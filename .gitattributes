# 跨平台换行符统一：仓库内一律以 LF 存储，避免 Mac/Windows 之间的 CRLF/LF 差异造成无意义改动
* text=auto eol=lf

# 显式声明源码/文本类型（始终 LF）
*.md    text eol=lf
*.py    text eol=lf
*.js    text eol=lf
*.css   text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.json  text eol=lf
*.txt   text eol=lf
*.html  text eol=lf

# 二进制文件：不做换行符转换，避免被破坏
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.webp  binary
*.bmp   binary
*.ico   binary
*.pdf   binary
